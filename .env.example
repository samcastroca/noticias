# Base de datos
DATABASE_URL=postgresql+asyncpg://noticias:noticias@postgres:5432/noticias

# Redis
REDIS_URL=redis://redis:6379/0

# Modelos (configurable por entorno)
EMBED_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini

# Ventana de tendencia (horas)
TREND_WINDOW_HOURS=2

# Clustering
HDBSCAN_MIN_CLUSTER_SIZE=3
HDBSCAN_MIN_SAMPLES=2

# Worker: intervalo de ingesta en segundos
INGEST_INTERVAL_SECONDS=300

# API
API_HOST=0.0.0.0
API_PORT=8000
